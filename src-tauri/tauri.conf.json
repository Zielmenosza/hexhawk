{
  "$schema": "https://schema.tauri.app.config/2",
  "productName": "HexHawk",
  "version": "1.0.0",
  "identifier": "com.hexhawk.app",
  "build": {
    "beforeBuildCommand": "yarn workspace hexhawk-ui build",
    "beforeDevCommand": "yarn workspace hexhawk-ui dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../HexHawk/dist"
  },
  "app": {
    "windows": [
      {
        "title": "HexHawk",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/16x16.png",
      "icons/24x24.png",
      "icons/32x32.png",
      "icons/48x48.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/icon.ico"
    ],
    "shortDescription": "Binary analysis and reverse engineering workbench",
    "longDescription": "HexHawk is a desktop binary analysis tool with four intelligence engines: NEST convergence analysis, TALON decompilation, STRIKE behavioral analysis, and ECHO cross-binary correlation.",
    "copyright": "Copyright © 2026 HexHawk Team",
    "category": "DeveloperTool",
    "createUpdaterArtifacts": false,
    "resources": [
      "../README.md",
      "../docs/HEXHAWK_FOR_DUMMIES.md",
      "../docs/HIGH_ASSURANCE_GUIDE.md"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "languages": [
          "English"
        ],
        "installMode": "perMachine"
      },
      "wix": {
        "language": "en-US",
        "template": null,
        "fragmentPaths": [
          "wix/hexhawk-registry.wxs"
        ],
        "componentGroupRefs": [
          "HexHawkEnterpriseRegistry"
        ],
        "componentRefs": [],
        "featureGroupRefs": [],
        "featureRefs": []
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": null,
      "signingIdentity": null,
      "providerShortName": null
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "dialog": null,
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhENjNBOUQ4MjVGMTJCRTIKUldUaUsvRWwyS2xqamZxWUpsRVRYSUJ6aStXNXVGcHdYVklrQUExRkxZQURIdGJjWGxJWE1qaDUK",
      "endpoints": [
        "https://hexhawk.ke/releases/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
