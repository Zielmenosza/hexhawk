{
  "$schema": "https://schema.tauri.app.config/2",
  "productName": "HexHawk",
  "version": "1.0.0",
  "identifier": "com.hexhawk.app",
  "build": {
    "beforeBuildCommand": "yarn workspace hexhawk-ui build",
    "beforeDevCommand": "yarn workspace hexhawk-ui dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../HexHawk/dist"
  },
  "app": {
    "windows": [
      {
        "title": "HexHawk",
        "width": 1200,
        "height": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "dialog": {}
  }
}