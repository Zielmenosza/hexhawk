{
  "name": "hexhawk-root",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "HexHawk",
    "packages/*"
  ],
  "scripts": {
    "dev": "node node_modules/@tauri-apps/cli/tauri.js dev",
    "build": "yarn workspace hexhawk-ui build",
    "tauri:dev": "node node_modules/@tauri-apps/cli/tauri.js dev",
    "tauri:build": "node node_modules/@tauri-apps/cli/tauri.js build",
    "release:hardening": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release/release-hardening.ps1",
    "release:native-probe": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release/run-native-parity-probe.ps1 -MsiPath ./target/release/bundle/msi/HexHawk_1.0.0_x64_en-US.msi",
    "test": "yarn workspace hexhawk-ui test",
    "test:coverage": "yarn workspace hexhawk-ui test:coverage",
    "typecheck": "yarn workspace hexhawk-ui exec tsc --noEmit",
    "lint:rust": "cargo clippy --workspace -- -D warnings",
    "test:rust": "cargo test --workspace"
  },
  "dependencies": {
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7"
  },
  "devDependencies": {
    "@types/react-window": "^2.0.0"
  },
  "description": "HexHawk is a native desktop reverse-engineering and binary-intelligence platform built with Rust, Tauri, React, and TypeScript.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zielmenosza/hexhawk.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Zielmenosza/hexhawk/issues"
  },
  "homepage": "https://github.com/Zielmenosza/hexhawk#readme"
}
