    "@tauri-apps/cli": "^2.9.5",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.3.0"
  }
