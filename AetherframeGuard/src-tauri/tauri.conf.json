{
  "$schema": "https://schema.tauri.app.config/2",
  "productName": "AetherframeGuard",
  "version": "0.1.0",
  "identifier": "com.hexhawk.aetherframe.guard",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5181",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AetherframeGuard",
        "width": 1120,
        "height": 780,
        "minWidth": 940,
        "minHeight": 620,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "../../src-tauri/icons/16x16.png",
      "../../src-tauri/icons/32x32.png",
      "../../src-tauri/icons/128x128.png",
      "../../src-tauri/icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["English"],
        "installMode": "perMachine"
      }
    }
  }
}
